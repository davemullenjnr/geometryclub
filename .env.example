# PUBLIC (safe to expose in browser bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_BUCKET=submit-photos

# SECRET (server/runtime only; never expose to browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=submit-photos

# SECRET (server/runtime only; never expose to browser)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=submit@geometryclub.org
OWNER_NOTIFICATION_EMAIL=submit@geometryclub.org

# SECRET (optional — if set, Netlify uses Postmark templates; see postmark/README.md)
# Postmark template aliases: owner = submission-notification, submitter = submission-confirmation
POSTMARK_OWNER_TEMPLATE_ALIAS=submission-notification
POSTMARK_USER_TEMPLATE_ALIAS=submission-confirmation
