# PUBLIC (safe to expose in browser bundle)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_BUCKET=

# SECRET (Netlify Functions only — never expose to browser)
# Prefer modern Supabase Secret API key (sb_secret_…) from Project Settings → API
SUPABASE_SECRET_KEY=
# Legacy name still supported: service_role JWT (if you have not migrated keys yet)
# SUPABASE_SERVICE_ROLE_KEY=

# OPTIONAL (Netlify): if functions do not see NEXT_PUBLIC_* at runtime, duplicate project URL + bucket:
# SUPABASE_URL=   (same as NEXT_PUBLIC_SUPABASE_URL)
# SUPABASE_BUCKET=   (same as NEXT_PUBLIC_SUPABASE_BUCKET)

# SECRET (server/runtime only; never expose to browser)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=
OWNER_NOTIFICATION_EMAIL=
